---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  endDate?: Date;
  time?: string;
  location?: string;
  address?: string;
  registrationUrl?: string;
  ogImage?: string;
}

const { title, description, date, endDate, time, location, address, registrationUrl, ogImage } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": title,
  "startDate": date.toISOString(),
  ...(endDate && { "endDate": endDate.toISOString() }),
  "description": description,
  "location": {
    "@type": "Place",
    "name": location || "Bastrop County Republican Party Office",
    "address": address || "443 Highway 71 West, Bastrop, TX 78602",
  },
  "organizer": {
    "@type": "Organization",
    "name": "Bastrop County Republican Party",
    "url": "https://bastropctygop.com",
  },
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType="article" jsonLd={eventSchema}>
  <Header slot="header" />
  <Breadcrumbs />

  <article class="py-10 lg:py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <h1 class="text-3xl lg:text-4xl font-extrabold text-text-primary leading-tight mb-6">{title}</h1>
          <div class="prose prose-lg max-w-none">
            <slot />
          </div>
        </div>

        <!-- Event Sidebar -->
        <aside class="lg:col-span-1">
          <div class="bg-gray-light rounded-xl p-6 sticky top-24 space-y-5">
            <h2 class="text-lg font-bold text-navy">Event Details</h2>

            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-semibold text-text-primary">{formattedDate}</p>
                {time && <p class="text-sm text-text-secondary">{time}</p>}
              </div>
            </div>

            {location && (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="font-semibold text-text-primary">{location}</p>
                  {address && <p class="text-sm text-text-secondary">{address}</p>}
                </div>
              </div>
            )}

            {registrationUrl && (
              <a
                href={registrationUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full text-center bg-red-primary hover:bg-red-dark text-white font-semibold py-3 px-5 rounded-lg transition-colors"
              >
                Register Now
              </a>
            )}

            <a href="/events/" class="block w-full text-center border-2 border-navy text-navy hover:bg-navy hover:text-white font-semibold py-3 px-5 rounded-lg transition-colors">
              View All Events
            </a>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
