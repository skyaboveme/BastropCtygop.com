---
import PageLayout from '../../layouts/PageLayout.astro';

const volunteerRoles = [
  { id: 'block_walking', label: 'Door Knocking & Block Walking', desc: 'Connect directly with voters in your neighborhood to distribute materials and share conservative messages.' },
  { id: 'phone_banking', label: 'Phone Banking & Outreach', desc: 'Call conservative voters to discuss upcoming elections, candidate details, and vote turnouts.' },
  { id: 'poll_watching', label: 'Poll Watching & Election Clerk', desc: 'Help protect the integrity of our elections by working as a poll watcher or clerk at local voting sites.' },
  { id: 'event_help', label: 'Event Set-Up & Planning', desc: 'Assist with coordinating, setting up, and managing local BCRP fundraisers, meetings, and conventions.' },
  { id: 'office_admin', label: 'Office Administration', desc: 'Help BCRP leadership with mailings, data entry, phone calls, and day-to-day office coordination in Bastrop.' },
  { id: 'house_meetings', label: 'Host a House Meeting', desc: 'Open your home to host informational meetings or candidate meet-and-greets for neighbors.' }
];

const volunteerSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Volunteer Action Center - Bastrop County Republican Party",
  "description": "Join the fight to keep Bastrop County red. Sign up to volunteer for phone banking, block walking, poll watching, and more.",
  "publisher": {
    "@type": "PoliticalParty",
    "name": "Bastrop County Republican Party",
    "url": "https://bastropctygop.com"
  }
};
---

<PageLayout 
  title="Volunteer Action Center" 
  description="Join the fight to keep Bastrop County red. Sign up to volunteer, phone bank, block walk, and defend conservative values."
  jsonLd={volunteerSchema}
>
  <div class="bg-gray-50/50 py-16 lg:py-24 min-h-screen">
    <div class="container mx-auto max-w-4xl px-4">
      
      <!-- Page Header -->
      <div class="mb-12 text-center max-w-2xl mx-auto">
        <span class="text-xs font-bold uppercase tracking-widest text-red-primary bg-red-primary/10 px-3 py-1 rounded-full">Get Involved</span>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-navy mt-4 mb-4">
          Volunteer Action Center
        </h1>
        <p class="text-text-secondary text-lg leading-relaxed">
          Conservatives win elections when neighbors talk to neighbors. Join our grassroots movement to defend liberty, recruit voters, and elect Republicans in Bastrop County!
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="bg-navy p-6 text-white text-center">
          <p class="text-sm font-semibold text-white/90">Pledge your support today — every hour makes a difference!</p>
        </div>

        <!-- Form Component -->
        <form 
          action="https://formsubmit.co/info@bastropctygop.com" 
          method="POST" 
          class="p-6 md:p-10 space-y-8"
        >
          <!-- Form Configuration (FormSubmit.co) -->
          <input type="hidden" name="_next" value="https://www.bastropctygop.com/events/submit-success/" />
          <input type="hidden" name="_subject" value="New BCRP Volunteer Sign-Up" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />

          <!-- Contact Information Grid -->
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-navy border-b border-gray-100 pb-2">1. Your Information</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold text-text-primary mb-2">Full Name <span class="text-red-primary">*</span></label>
                <input 
                  type="text" 
                  name="name" 
                  id="name" 
                  required 
                  placeholder="John Doe"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-text-primary mb-2">Email Address <span class="text-red-primary">*</span></label>
                <input 
                  type="email" 
                  name="email" 
                  id="email" 
                  required 
                  placeholder="john.doe@example.com"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-sm font-semibold text-text-primary mb-2">Phone Number <span class="text-red-primary">*</span></label>
                <input 
                  type="tel" 
                  name="phone" 
                  id="phone" 
                  required 
                  placeholder="(512) 555-0199"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary"
                />
              </div>

              <div>
                <div class="flex items-center justify-between mb-2">
                  <label for="precinct" class="block text-sm font-semibold text-text-primary">Precinct Number <span class="text-text-secondary font-normal text-xs">(Optional)</span></label>
                  <a href="/resources/precinct-maps/" class="text-xs font-semibold text-red-primary hover:underline">Find Precinct</a>
                </div>
                <input 
                  type="text" 
                  name="precinct" 
                  id="precinct" 
                  placeholder="e.g. 2011"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary"
                />
              </div>
            </div>
          </div>

          <!-- Interests / Volunteer Roles -->
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-navy border-b border-gray-100 pb-2">2. Select Your Interest Areas</h3>
            <p class="text-xs text-text-secondary">Choose one or more ways you would like to help support the conservative cause in Bastrop County:</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {volunteerRoles.map((role) => (
                <label class="flex items-start gap-3 p-4 bg-gray-50 hover:bg-gray-100/70 border border-gray-200 rounded-xl cursor-pointer transition-colors group">
                  <input 
                    type="checkbox" 
                    name="interests" 
                    value={role.label}
                    class="mt-1 w-4.5 h-4.5 text-red-primary bg-white border-gray-300 rounded focus:ring-red-primary focus:ring-2"
                  />
                  <div>
                    <span class="block text-sm font-bold text-navy group-hover:text-red-primary transition-colors">{role.label}</span>
                    <span class="block text-xs text-text-secondary mt-1 leading-relaxed">{role.desc}</span>
                  </div>
                </label>
              ))}
            </div>
          </div>

          <!-- Time Commitement -->
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-navy border-b border-gray-100 pb-2">3. Commitment & Comments</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="hours" class="block text-sm font-semibold text-text-primary mb-2">Pledged Time Commitment</label>
                <select 
                  id="hours"
                  name="hours"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary h-[46px]"
                >
                  <option value="under_5">Less than 5 hours per month</option>
                  <option value="5_10">5 - 10 hours per month</option>
                  <option value="10_20">10 - 20 hours per month</option>
                  <option value="over_20">20+ hours per month</option>
                </select>
              </div>
            </div>

            <div>
              <label for="comments" class="block text-sm font-semibold text-text-primary mb-2">Comments or Special Skills <span class="text-text-secondary font-normal text-xs">(Optional)</span></label>
              <textarea 
                name="comments" 
                id="comments" 
                rows="4" 
                placeholder="Share any special skills (e.g. data analysis, legal, design, public speaking) or ask any questions here..."
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary resize-y"
              ></textarea>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="pt-4 border-t border-gray-100 flex justify-end">
            <button 
              type="submit" 
              class="w-full md:w-auto bg-red-primary hover:bg-red-dark text-white font-extrabold text-sm px-8 py-4 rounded-lg transition-transform hover:-translate-y-0.5 shadow-lg"
            >
              Submit Volunteer Application
            </button>
          </div>

        </form>
      </div>

    </div>
  </div>
</PageLayout>
