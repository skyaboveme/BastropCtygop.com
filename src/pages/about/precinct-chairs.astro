---
import PageLayout from '../../layouts/PageLayout.astro';
import PrecinctCard from '../../components/ui/PrecinctCard.astro';

const precinctChairs = [
  { precinct: '1003', name: 'Cathy Martinez', email: 'precinctchair1003@bastropctygop.com' },
  { precinct: '1006', name: 'Michael Dickson', email: 'mike@goofythat.com' },
  { precinct: '1007', name: 'Monica Carson', email: 'precinctchair1007@bastropctygop.com' },
  { precinct: '1008', name: 'Deborah Layland', email: 'precinctchair1008@bastropctygop.com' },
  { precinct: '1009', name: 'Kim Casper', email: 'precinctchair1009@bastropctygop.com' },
  { precinct: '2010', name: 'Chris Kirby', email: 'precinctchair2010@bastropctygop.com' },
  { precinct: '2011', name: 'Beverly Watts', email: 'precinctchair2011@bastropctygop.com' },
  { precinct: '2012', name: 'Brian Thornton', email: 'precinctchair2012@bastropctygop.com' },
  { precinct: '2013', name: 'Doug Kelsay', email: 'dougk@keltecsystems.com' },
  { precinct: '2014', name: 'Shari Wyatt', email: 'shari.wyatt.mail@gmail.com' },
  { precinct: '2015', name: 'Debra Wilson', email: 'villernc1@yahoo.com' },
  { precinct: '2016', name: 'James Page', email: 'jamespageBCRP@gmail.com' },
  { precinct: '3017', name: 'Mark L. Torrey', email: 'markltorreybcrp@gmail.com' },
  { precinct: '3018', name: 'Sue Beck', email: 'smbeck360@yahoo.com' },
  { precinct: '3019', name: 'Debra Carter', email: 'carter512djwc@gmail.com' },
  { precinct: '4021', name: 'Amber Wilson', email: 'desertrose2469@yahoo.com' },
  { precinct: '4022', name: 'Terry Pickering', email: 'terryp1003@gmail.com', note: 'Resigned 06/2026' },
  { precinct: '4023', name: 'Cliff Sparks', email: 'dewar9893@mypacks.net' },
  { precinct: '4024', name: 'Jerry Able', email: 'precinctchair4024@bastropctygop.com' },
  { precinct: '4026', name: 'W.C. Estes', email: 'precinctchair4026@bastropctygop.com' },
];

---

<PageLayout
  title="Precinct Chairs"
  description="Find your Bastrop County Republican Precinct Chair. Precinct Chairs maximize the Republican vote by getting people involved, identifying voters, and turning out voters."
>
  <section class="py-10 lg:py-16">
    <div class="container max-w-5xl">
      <h1 class="text-3xl lg:text-4xl font-extrabold text-text-primary mb-4">Precinct Chairs</h1>
      <p class="text-lg text-text-secondary mb-4 max-w-3xl">
        Your Precinct Chairs' main job is to maximize the Republican vote in their precinct by Getting People In Your Precinct Involved, Identifying Voters, Registering Voters, Informing Voters and Turning Out Voters.
      </p>
      <p class="text-base text-text-secondary mb-8">
        Click on a name to send email to your Precinct Chair.
      </p>

      <!-- SREC Representatives -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-navy mb-4 flex items-center gap-2">
          <span class="w-2 h-2 bg-red-primary rounded-full"></span>
          State Republican Executive Committee (SREC)
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="rounded-xl border border-gray-medium bg-navy/5 p-4">
            <div class="flex items-center gap-3">
              <div class="shrink-0 w-12 h-12 rounded-lg bg-red-primary text-white flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-[10px] font-bold uppercase tracking-widest text-text-muted">SREC Committeewoman</p>
                <h3 class="font-bold text-sm text-text-primary">Susan Lucus</h3>
                <div class="flex flex-wrap items-center gap-2 mt-1">
                  <a href="mailto:lucassel@att.net" class="inline-flex items-center gap-1 text-xs text-navy hover:text-red-primary transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    Email
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-gray-medium bg-navy/5 p-4">
            <div class="flex items-center gap-3">
              <div class="shrink-0 w-12 h-12 rounded-lg bg-red-primary text-white flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-[10px] font-bold uppercase tracking-widest text-text-muted">SREC Committeeman</p>
                <h3 class="font-bold text-sm text-text-primary">Justin Bezner</h3>
                <div class="flex flex-wrap items-center gap-2 mt-1">
                  <a href="mailto:justin.bcrp@yahoo.com" class="inline-flex items-center gap-1 text-xs text-navy hover:text-red-primary transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    Email
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Search -->
      <div class="mb-8">
        <div class="relative max-w-md">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="precinct-search"
            placeholder="Search by precinct number or name..."
            class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-medium focus:outline-none focus:ring-2 focus:ring-navy focus:border-transparent bg-white"
          />
        </div>
      </div>

      <!-- Precinct Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="precinct-grid">
        {precinctChairs.map((chair) => (
          <div data-precinct={chair.precinct} data-name={chair.name.toLowerCase()}>
            <PrecinctCard
              precinct={chair.precinct}
              name={chair.name}
              email={chair.email}
              note={chair.note}
            />
          </div>
        ))}
      </div>

      <!-- Precinct Map Link -->
      <div class="mt-10 p-6 bg-gray-light rounded-xl border border-gray-medium text-center">
        <h3 class="text-lg font-bold text-text-primary mb-2">Not sure which precinct you're in?</h3>
        <p class="text-sm text-text-secondary mb-4">Check the Bastrop County precinct map to find your precinct number.</p>
        <a href="/resources/precinct-maps/" class="inline-flex items-center gap-2 bg-navy hover:bg-navy-dark text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors">
          View Precinct Maps
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const searchInput = document.getElementById('precinct-search') as HTMLInputElement;
  const grid = document.getElementById('precinct-grid');
  const items = grid?.querySelectorAll('[data-precinct]');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    items?.forEach((item) => {
      const precinct = item.getAttribute('data-precinct') || '';
      const name = item.getAttribute('data-name') || '';
      const match = !query || precinct.includes(query) || name.includes(query);
      (item as HTMLElement).style.display = match ? '' : 'none';
    });
  });
</script>
