---
import PageLayout from '../../layouts/PageLayout.astro';
import PrecinctCard from '../../components/ui/PrecinctCard.astro';

const precinctChairs = [
  { precinct: '1001', name: 'Vacant', vacant: true },
  { precinct: '1002', name: 'Vacant', vacant: true },
  { precinct: '1003', name: 'Cathy Martinez', email: 'precinctchair1003@bastropctygop.com' },
  { precinct: '1004', name: 'Vacant', vacant: true },
  { precinct: '1005', name: 'Vacant', vacant: true },
  { precinct: '1006', name: 'Michael Dickson', email: 'precinctchair1006@bastropctygop.com' },
  { precinct: '1007', name: 'Monica Carson', email: 'precinctchair1007@bastropctygop.com', phone: '512-426-5950' },
  { precinct: '1008', name: 'Deborah Layland', email: 'precinctchair1008@bastropctygop.com' },
  { precinct: '1009', name: 'Kim Casper', email: 'precinctchair1009@bastropctygop.com' },
  { precinct: '2010', name: 'Chris Kirby', email: 'precinctchair2010@bastropctygop.com' },
  { precinct: '2011', name: 'Beverly Watts', email: 'precinctchair2011@bastropctygop.com' },
  { precinct: '2012', name: 'Brian Thornton', email: 'precinctchair2012@bastropctygop.com' },
  { precinct: '2013', name: 'Doug Kelsay', email: 'precinctchair2013@bastropctygop.com' },
  { precinct: '2014', name: 'Shari Wyatt', email: 'precinctchair2014@bastropctygop.com' },
  { precinct: '2015', name: 'Vacant', vacant: true },
  { precinct: '2016', name: 'James Page', email: 'precinctchair2016@bastropctygop.com' },
  { precinct: '3017', name: 'Mark L. Torrey', email: 'precinctchair3017@bastropctygop.com' },
  { precinct: '3018', name: 'Sue Beck', email: 'precinctchair3018@bastropctygop.com' },
  { precinct: '3019', name: 'Debra Carter', email: 'precinctchair3019@bastropctygop.com' },
  { precinct: '3020', name: 'Vacant', vacant: true },
  { precinct: '4021', name: 'Amber Wilson', email: 'precinctchair4021@bastropctygop.com' },
  { precinct: '4022', name: 'Terry Pickering', email: 'precinctchair4022@bastropctygop.com' },
  { precinct: '4023', name: 'Amber Sparks', email: 'precinctchair4023@bastropctygop.com' },
  { precinct: '4024', name: 'Jerry Able', email: 'precinctchair4024@bastropctygop.com' },
  { precinct: '4025', name: 'Vacant', vacant: true },
  { precinct: '4026', name: 'W.C. Estes', email: 'precinctchair4026@bastropctygop.com' },
];
---

<PageLayout
  title="Precinct Chairs"
  description="Find your Bastrop County Republican Precinct Chair. Precinct Chairs maximize the Republican vote by getting people involved, identifying voters, and turning out voters."
>
  <section class="py-10 lg:py-16">
    <div class="container max-w-5xl">
      <h1 class="text-3xl lg:text-4xl font-extrabold text-text-primary mb-4">Precinct Chairs</h1>
      <p class="text-lg text-text-secondary mb-4 max-w-3xl">
        Your Precinct Chairs' main job is to maximize the Republican vote in their precinct by Getting People In Your Precinct Involved, Identifying Voters, Registering Voters, Informing Voters and Turning Out Voters.
      </p>
      <p class="text-base text-text-secondary mb-8">
        Click on a name to send email to your Precinct Chair.
      </p>

      <!-- Search -->
      <div class="mb-8">
        <div class="relative max-w-md">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="precinct-search"
            placeholder="Search by precinct number or name..."
            class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-medium focus:outline-none focus:ring-2 focus:ring-navy focus:border-transparent bg-white"
          />
        </div>
      </div>

      <!-- Precinct Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="precinct-grid">
        {precinctChairs.map((chair) => (
          <div data-precinct={chair.precinct} data-name={chair.name.toLowerCase()}>
            <PrecinctCard
              precinct={chair.precinct}
              name={chair.name}
              email={chair.email}
              phone={chair.phone}
              vacant={chair.vacant}
            />
          </div>
        ))}
      </div>

      <!-- Precinct Map Link -->
      <div class="mt-10 p-6 bg-gray-light rounded-xl border border-gray-medium text-center">
        <h3 class="text-lg font-bold text-text-primary mb-2">Not sure which precinct you're in?</h3>
        <p class="text-sm text-text-secondary mb-4">Check the Bastrop County precinct map to find your precinct number.</p>
        <a href="/resources/precinct-maps/" class="inline-flex items-center gap-2 bg-navy hover:bg-navy-dark text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors">
          View Precinct Maps
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const searchInput = document.getElementById('precinct-search') as HTMLInputElement;
  const grid = document.getElementById('precinct-grid');
  const items = grid?.querySelectorAll('[data-precinct]');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    items?.forEach((item) => {
      const precinct = item.getAttribute('data-precinct') || '';
      const name = item.getAttribute('data-name') || '';
      const match = !query || precinct.includes(query) || name.includes(query);
      (item as HTMLElement).style.display = match ? '' : 'none';
    });
  });
</script>
