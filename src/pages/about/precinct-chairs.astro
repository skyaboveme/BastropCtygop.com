  { precinct: '1005', name: 'Beverly Watts', email: 'bevwatts2011@gmail.com' },
  { precinct: '1006', name: 'Michael Dickson', email: 'mike@goofythat.com' },
  { precinct: '1007', name: 'Monica Carson', email: 'precinctchair1007@bastropctygop.com' },
  { precinct: '1008', name: 'Lesley Guthrie', email: 'lesleygguthrie@gmail.com' },
  { precinct: '1009', name: 'Kim Casper', email: 'kcaspro2@yahoo.com' },
  { precinct: '2010', name: 'Chris Kirby', email: 'chris@thebridgefieldgroup.com' },
  { precinct: '2011', name: 'Beverly Watts', email: 'bevwatts2011@gmail.com' },
  { precinct: '2013', name: 'Doug Kelsay', email: 'dougk@keltecsystems.com' },
  { precinct: '2014', name: 'Shari Wyatt', email: 'shari.wyatt.mail@gmail.com' },
  { precinct: '2015', name: 'Debra Wilson', email: 'villernc1@yahoo.com' },
  { precinct: '2016', name: 'James Page', email: 'jamespageBCRP@gmail.com' },
  { precinct: '3017', name: 'Mark L. Torrey', email: 'markltorreybcrp@gmail.com' },
  { precinct: '3018', name: 'Sue Beck', email: 'smbeck360@yahoo.com' },
  { precinct: '3019', name: 'Debra Carter', email: 'carter512djwc@gmail.com' },
  { precinct: '4021', name: 'Amber Wilson', email: 'desertrose2469@yahoo.com' },
  { precinct: '4023', name: 'Cliff Sparks', email: 'dewar9893@mypacks.net' },
];

---

<PageLayout
  title="Precinct Chairs"
  description="Find your Bastrop County Republican Precinct Chair. Precinct Chairs maximize the Republican vote by getting people involved, identifying voters, and turning out voters."
>
  <section class="py-10 lg:py-16">
    <div class="container max-w-5xl">
      <h1 class="text-3xl lg:text-4xl font-extrabold text-text-primary mb-4">Precinct Chairs</h1>
      <p class="text-lg text-text-secondary mb-4 max-w-3xl">
        Your Precinct Chairs' main job is to maximize the Republican vote in their precinct by Getting People In Your Precinct Involved, Identifying Voters, Registering Voters, Informing Voters and Turning Out Voters.
      </p>
      <p class="text-base text-text-secondary mb-8">
        Click on a name to send email to your Precinct Chair.
      </p>

      <!-- Search -->
      <div class="mb-8">
        <div class="relative max-w-md">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="precinct-search"
            placeholder="Search by precinct number or name..."
            class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-medium focus:outline-none focus:ring-2 focus:ring-navy focus:border-transparent bg-white"
          />
        </div>
      </div>

      <!-- Precinct Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="precinct-grid">
        {precinctChairs.map((chair) => (
          <div data-precinct={chair.precinct} data-name={chair.name.toLowerCase()}>
            <PrecinctCard
              precinct={chair.precinct}
              name={chair.name}
              email={chair.email}
              note={chair.note}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const searchInput = document.getElementById('precinct-search') as HTMLInputElement;
  const grid = document.getElementById('precinct-grid');
  const items = grid?.querySelectorAll('[data-precinct]');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    items?.forEach((item) => {
      const precinct = item.getAttribute('data-precinct') || '';
      const name = item.getAttribute('data-name') || '';
      const match = !query || precinct.includes(query) || name.includes(query);
      (item as HTMLElement).style.display = match ? '' : 'none';
    });
  });
</script>
