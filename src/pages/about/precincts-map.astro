---
import PageLayout from '../../layouts/PageLayout.astro';
import precinctsGeojson from '../../data/precincts-geojson.json';

const precinctChairs = [
  { precinct: '1001', name: 'Monica Carson', email: 'precinctchair1007@bastropctygop.com', district: '10' },
  { precinct: '1002', name: 'Lesley Guthrie', email: 'lesleygguthrie@gmail.com', district: '10' },
  { precinct: '1003', name: 'Cathy Martinez', email: 'cathymartinez141@gmail.com', district: '10' },
  { precinct: '1004', name: 'Debbie Denny', email: 'ddenny001@gmail.com', district: '10' },
  { precinct: '1005', name: 'Beverly Watts', email: 'bevwatts2011@gmail.com', district: '27' },
  { precinct: '1006', name: 'Michael Dickson', email: 'mike@goofythat.com', district: '10' },
  { precinct: '1007', name: 'Monica Carson', email: 'precinctchair1007@bastropctygop.com', district: '27' },
  { precinct: '1008', name: 'Lesley Guthrie', email: 'lesleygguthrie@gmail.com', district: '27' },
  { precinct: '1009', name: 'Kim Casper', email: 'kcaspro2@yahoo.com', district: '27' },
  { precinct: '2010', name: 'Chris Kirby', email: 'chris@thebridgefieldgroup.com', district: '10' },
  { precinct: '2011', name: 'Beverly Watts', email: 'bevwatts2011@gmail.com', district: '27' },
  { precinct: '2012', name: 'Vacant', email: '', vacant: true, district: '10' },
  { precinct: '2013', name: 'Doug Kelsay', email: 'dougk@keltecsystems.com', district: '10' },
  { precinct: '2014', name: 'Shari Wyatt', email: 'shari.wyatt.mail@gmail.com', district: '10' },
  { precinct: '2015', name: 'Debra Wilson', email: 'villernc1@yahoo.com', district: '10' },
  { precinct: '2016', name: 'James Page', email: 'jamespageBCRP@gmail.com', district: '10' },
  { precinct: '3017', name: 'Mark L. Torrey', email: 'markltorreybcrp@gmail.com', district: '27' },
  { precinct: '3018', name: 'Sue Beck', email: 'smbeck360@yahoo.com', district: '27' },
  { precinct: '3019', name: 'Debra Carter', email: 'carter512djwc@gmail.com', district: '27' },
  { precinct: '3020', name: 'Vacant', email: '', vacant: true, district: '27' },
  { precinct: '4021', name: 'Amber Wilson', email: 'desertrose2469@yahoo.com', district: '10', note: 'Split in 2023' },
  { precinct: '4022', name: 'Vacant', email: '', vacant: true, note: 'Resigned 06/2026', district: '10' },
  { precinct: '4023', name: 'Cliff Sparks', email: 'dewar9893@mypacks.net', district: '10', parent: '4022' },
  { precinct: '4024', name: 'Vacant', email: '', vacant: true, district: '10', parent: '4022' },
  { precinct: '4025', name: 'Vacant', email: '', vacant: true, district: '10', parent: '4022' },
  { precinct: '4026', name: 'Vacant', email: '', vacant: true, district: '10', parent: '4021' }
