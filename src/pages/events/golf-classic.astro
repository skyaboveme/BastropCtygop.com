---
import PageLayout from '../../layouts/PageLayout.astro';

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "BCRP 4th Annual Golf Classic",
  "startDate": "2026-04-10T08:00:00-05:00",
  "location": {
    "@type": "Place",
    "name": "ColoVista Golf Club",
    "address": "100 Country Club Drive, Bastrop, TX",
  },
  "organizer": {
    "@type": "Organization",
    "name": "Bastrop County Republican Party",
    "url": "https://bastropctygop.com",
  },
  "description": "4th Annual Golf Classic fundraiser for the Bastrop County Republican Party",
};
---

<PageLayout
  title="Annual Golf Classic"
  description="BCRP's 4th Annual Golf Classic at ColoVista Golf Club, Bastrop, TX. April 10th, 2026. Registration now open."
  jsonLd={eventSchema}
>
  <section class="py-10 lg:py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <h1 class="text-3xl lg:text-4xl font-extrabold text-text-primary mb-6">4th Annual Golf Classic</h1>

          <div class="prose prose-lg max-w-none prose-headings:text-navy prose-a:text-red-primary">
            <p class="text-xl text-text-secondary">Registration for BCRP's 4th Annual Golf Classic is now <strong>OPEN</strong>.</p>

            <p>Join us at ColoVista Golf Club for a premier day of golf, camaraderie, and support for the Bastrop County Republican Party. This flagship fundraising event brings together Republicans from across the county for competitive play, great food, prizes, and networking with fellow conservatives.</p>

            <h2>Event Details</h2>
            <ul>
              <li><strong>Format:</strong> Four Man Scramble</li>
              <li><strong>Check-in:</strong> 11:00 AM</li>
              <li><strong>Shotgun Start:</strong> 12:00 PM</li>
              <li><strong>Location:</strong> ColoVista Golf Club, 100 Country Club Drive, Bastrop, Texas 78602</li>
            </ul>

            <h2>Individual and Foursome Teams</h2>
            <ul>
              <li><strong>Individual Player:</strong> $85</li>
              <li><strong>Foursome Team:</strong> $340</li>
            </ul>

            <h2>Sponsorships</h2>
            <div class="space-y-4 not-prose">
              <div class="bg-gray-light p-4 rounded-lg border-l-4 border-navy">
                <h3 class="text-lg font-bold text-navy">Ace Sponsor $1000</h3>
                <p class="text-sm text-text-secondary mt-1">Recognized as Ace Sponsor on BCRP Website for 3 months and on event banner, 1-Hole Sponsor | 1-Foursome Team | 2 General Admission to Boots and BBQ (September 2025)</p>
              </div>
              <div class="bg-gray-light p-4 rounded-lg border-l-4 border-navy/80">
                <h3 class="text-lg font-bold text-navy">Eagle Sponsor $750</h3>
                <p class="text-sm text-text-secondary mt-1">Recognized as Eagle Sponsor on BCRP Website for 3 months and on event banner, 1-Hole Sponsor | 1-Foursome Team</p>
              </div>
              <div class="bg-gray-light p-4 rounded-lg border-l-4 border-navy/60">
                <h3 class="text-lg font-bold text-navy">Birdie Sponsor $500</h3>
                <p class="text-sm text-text-secondary mt-1">Recognized as Birdie Sponsor on BCRP Website for 3 months and on event banner, 1-Hole Sponsor</p>
              </div>
              <div class="bg-gray-light p-4 rounded-lg border-l-4 border-navy/40">
                <h3 class="text-lg font-bold text-navy">Meal Sponsor $250</h3>
                <p class="text-sm text-text-secondary mt-1">Recognized as Meal Sponsor on BCRP Website for 3 months and on event banner</p>
              </div>
              <div class="bg-gray-light p-4 rounded-lg border-l-4 border-navy/20">
                <h3 class="text-lg font-bold text-navy">Hole Sponsor $150</h3>
                <p class="text-sm text-text-secondary mt-1">Recognized as Hole Sponsor on BCRP Website for 3 months and on event banner</p>
              </div>
              <div class="bg-gray-light p-4 rounded-lg border-l-4 border-gray-medium">
                <h3 class="text-lg font-bold text-navy">General Donor</h3>
                <p class="text-sm text-text-secondary mt-1">Specify the amount of your Generous Donation</p>
              </div>
            </div>

            <div class="mt-12 mb-8 rounded-xl shadow-lg border border-gray-medium overflow-hidden bg-white">
              <iframe 
                title="Registration Form"
                height="2400" 
                allowtransparency="true" 
                frameborder="0" 
                scrolling="yes" 
                class="w-full border-none"
                src="https://bastropctygop.wufoo.com/embed/bcrp-4th-annual-golf-classic/"
              ></iframe>
            </div>

            <h2>Registration & Donation Questions</h2>
            <p><strong>Contact Curtis Courtney</strong> by phone: (512) 925-6034, or by email.</p>
            <p>
              Register/Donate ONLINE today or pickup a flyer/application at the BCRP office located at:<br/>
              <strong>443 Highway 71 West<br/>Bastrop Texas 78602</strong>
            </p>
          </div>
        </div>

        <!-- Event Sidebar -->
        <aside class="lg:col-span-1">
          <div class="bg-gray-light rounded-xl p-6 sticky top-24 space-y-5">
            <h2 class="text-lg font-bold text-navy">Event Details</h2>

            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-semibold text-text-primary">Friday, April 10, 2026</p>
                <p class="text-sm text-text-secondary">12:00 PM Shotgun Start</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="font-semibold text-text-primary">ColoVista Golf Club</p>
                <p class="text-sm text-text-secondary">100 Country Club Drive, Bastrop, TX</p>
              </div>
            </div>

            <a href="/events/" class="block w-full text-center border-2 border-navy text-navy hover:bg-navy hover:text-white font-semibold py-3 px-5 rounded-lg transition-colors">
              View All Events
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</PageLayout>
