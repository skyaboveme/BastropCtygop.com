---
interface Props {
  headline: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  backgroundImage?: string;
  mobileBackgroundImage?: string;
}

const {
  headline,
  subheadline,
  primaryCta,
  secondaryCta,
  backgroundImage,
  mobileBackgroundImage,
} = Astro.props;
---

<section class="relative bg-navy overflow-hidden min-h-[100vh] lg:min-h-[85vh] flex flex-col justify-center">
  {backgroundImage && (
    <div class="absolute inset-0 bg-black">
      {mobileBackgroundImage ? (
        <picture>
          <source media="(min-width: 768px)" srcset={backgroundImage} />
          <img 
            src={mobileBackgroundImage} 
            alt="" 
            class="w-full h-full object-cover object-center" 
          />
        </picture>
      ) : (
        <img 
          src={backgroundImage} 
          alt="" 
          class="w-full h-full object-cover object-center" 
        />
      )}
      <!-- Neutral dark overlay for text readability -->
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
  )}
  <!-- Subtle pattern overlay -->
  {!backgroundImage && (
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
  )}
  <!-- Red accent bar at top -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-red-primary"></div>

  <!-- Bottom padding increased so buttons clear the background wave overlay -->
  <div class="container relative z-10 pt-20 pb-64 lg:pt-32 lg:pb-56 text-center md:text-left">
    <div class="max-w-3xl">
      <div class="inline-block mb-6 px-4 py-1.5 rounded-full bg-white/10 backdrop-blur border border-white/20 text-white text-sm font-bold uppercase tracking-[0.15em] shadow-sm">
        Welcome to Bastrop County
      </div>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif font-bold text-white leading-[1.1] mb-6 drop-shadow-xl" set:html={headline}>
      </h1>
      {subheadline && (
        <p class="text-lg md:text-xl lg:text-2xl text-white/90 mb-8 lg:mb-10 leading-relaxed font-medium drop-shadow-md">
          {subheadline}
        </p>
      )}
      {(primaryCta || secondaryCta) && (
        <div class="flex flex-col sm:flex-row items-center md:justify-start justify-center gap-4">
          {primaryCta && (
            <a
              href={primaryCta.href}
              class="inline-flex items-center justify-center bg-red-primary hover:bg-red-dark text-white font-bold text-lg h-14 px-8 rounded-md transition-transform hover:scale-105 shadow-xl w-full sm:w-auto"
            >
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white border border-white/40 font-bold text-lg h-14 px-8 rounded-md backdrop-blur transition-colors w-full sm:w-auto"
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 48h1440V16C1200 0 960 32 720 32S240 0 0 16v32z" fill="white" />
    </svg>
  </div>
</section>
