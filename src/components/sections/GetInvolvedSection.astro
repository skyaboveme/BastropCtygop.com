---
// GetInvolvedSection.astro
---

<section class="py-16 md:py-24 bg-gray-50/50">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-navy mb-6">
        Get Involved
      </h2>
      <p class="text-text-secondary text-lg leading-relaxed">
        There are many ways to serve your community and support the cause. Choose how you want to make an impact today.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Card 1: Attend Events -->
      <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_30px_-4px_rgba(0,0,0,0.1)] transition-shadow duration-300 flex flex-col">
        <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center mb-8">
          <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-navy mb-4">
          Attend Events
        </h3>
        <p class="text-text-secondary leading-relaxed mb-8 flex-grow">
          Join us for monthly meetings, candidate forums, and community gatherings.
        </p>
        <a href="/events/" class="inline-flex items-center gap-2 text-navy font-bold hover:text-blue-600 transition-colors group mt-auto">
          View Calendar
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

      <!-- Card 2: Stay Informed -->
      <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_30px_-4px_rgba(0,0,0,0.1)] transition-shadow duration-300 flex flex-col">
        <div class="w-14 h-14 rounded-2xl bg-red-50 flex items-center justify-center mb-8">
          <svg class="w-7 h-7 text-red-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-navy mb-4">
          Stay Informed
        </h3>
        <p class="text-text-secondary leading-relaxed mb-8 flex-grow">
          Get the latest updates on local issues, party news, and election information.
        </p>
        <a href="/news/" class="inline-flex items-center gap-2 text-navy font-bold hover:text-red-primary transition-colors group mt-auto">
          Read News
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

      <!-- Card 3: Volunteer -->
      <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_30px_-4px_rgba(0,0,0,0.1)] transition-shadow duration-300 flex flex-col">
        <div class="w-14 h-14 rounded-2xl bg-[#fff9ed] flex items-center justify-center mb-8">
          <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-navy mb-4">
          Volunteer
        </h3>
        <p class="text-text-secondary leading-relaxed mb-8 flex-grow">
          We need your help! Sign up to block walk, poll watch, or help at events.
        </p>
        <a href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-navy font-bold hover:text-gold transition-colors group mt-auto">
          Join Us
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

    </div>

  </div>
</section>
