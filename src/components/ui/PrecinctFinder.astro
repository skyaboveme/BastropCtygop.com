---

<div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden max-w-4xl mx-auto my-12">
  <div class="bg-navy p-6 md:p-8 text-white">
    <h3 class="text-2xl font-bold font-serif mb-2 text-white">Find Your Precinct & Chair</h3>
    <p class="text-white/80 text-sm leading-relaxed">
      Type your street name or subdivision (e.g. <strong>Tahitian Village</strong>, <strong>Circle D</strong>, <strong>Elgin</strong>) or select a precinct below to locate your Precinct Chair, map, and voting location.
    </p>
  </div>

  <div class="p-6 md:p-8 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Search Input -->
      <div>
        <label for="address-lookup" class="block text-xs font-bold uppercase tracking-wider text-text-secondary mb-2">Search by Neighborhood or Street</label>
        <div class="relative">
          <input 
            type="text" 
            id="address-lookup" 
            placeholder="e.g. Tahitian Village, Elgin, FM 535..."
            class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary"
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- Dropdown Select -->
      <div>
        <label for="precinct-select" class="block text-xs font-bold uppercase tracking-wider text-text-secondary mb-2">Select Precinct Directly</label>
        <select 
          id="precinct-select"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent bg-gray-50 text-sm text-text-primary h-[46px]"
        >
          <option value="">-- Choose Precinct --</option>
          {precincts.map((pct) => (
            <option value={pct.number}>Precinct {pct.number} ({pct.name === 'Vacant' ? 'Vacant' : pct.name})</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Live Search Results -->
    <div id="lookup-results" class="hidden space-y-6 pt-4 border-t border-gray-100">
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
        <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
          <div>
            <span class="inline-block bg-red-primary text-white font-extrabold text-sm px-4 py-1.5 rounded-full uppercase tracking-wider mb-2">
              Precinct <span id="res-number">1003</span>
            </span>
            <h4 class="text-xl font-bold text-navy" id="res-coverage">Elgin City Limits</h4>
          </div>
          
          <div id="res-map-container">
            <a 
              href="#" 
              id="res-map-link" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center gap-1.5 bg-navy/10 hover:bg-navy/20 text-navy font-bold text-xs px-4 py-2 rounded-lg transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
              Download PDF Map
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Representative/Chair details -->
          <div class="bg-white p-5 rounded-lg border border-gray-100 shadow-sm flex flex-col justify-between">
            <div>
              <span class="block text-[10px] uppercase tracking-wider font-extrabold text-gray-400 mb-1">Precinct Chair</span>
              <h5 class="text-lg font-bold text-text-primary mb-1" id="res-chair-name">Cathy Martinez</h5>
              <p class="text-xs text-text-secondary mb-4" id="res-chair-status">Official Republican Representative</p>
            </div>
            
            <div id="res-chair-contact">
              <a href="#" id="res-chair-email" class="inline-flex items-center gap-1.5 text-sm font-semibold text-red-primary hover:text-red-dark transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Email Precinct Chair
              </a>
              <p id="res-chair-phone" class="text-xs text-text-secondary mt-1 hidden"></p>
            </div>
            
            <div id="res-chair-vacant" class="hidden">
              <p class="text-sm text-text-secondary mb-4">This precinct is currently vacant. We need conservative leadership in your area!</p>
              <a href="/resources/volunteer/" class="inline-flex items-center gap-1.5 bg-red-primary hover:bg-red-dark text-white font-bold text-xs px-4 py-2.5 rounded-lg transition-colors">
                Apply to be Precinct Chair
              </a>
            </div>
          </div>

          <!-- Polling Location details -->
          <div class="bg-white p-5 rounded-lg border border-gray-100 shadow-sm flex flex-col justify-between">
            <div>
              <span class="block text-[10px] uppercase tracking-wider font-extrabold text-gray-400 mb-1">Election Day Polling Place</span>
              <h5 class="text-base font-bold text-navy mb-2" id="res-poll-place">Elgin Public Library</h5>
              <p class="text-xs text-text-secondary leading-relaxed" id="res-poll-details">404 N Hwy 95, Elgin, TX 78621</p>
            </div>
            
            <div class="pt-4">
              <a 
                href="#" 
                id="res-poll-directions" 
                target="_blank" 
                rel="noopener noreferrer" 
                class="inline-flex items-center gap-1.5 text-xs font-semibold text-navy hover:text-red-primary transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                Get Directions (Google Maps)
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ precincts }}>
  const lookupInput = document.getElementById('address-lookup');
  const selectElement = document.getElementById('precinct-select');
  const resultsContainer = document.getElementById('lookup-results');

  const resNumber = document.getElementById('res-number');
  const resCoverage = document.getElementById('res-coverage');
  const resMapLink = document.getElementById('res-map-link');
  const resChairName = document.getElementById('res-chair-name');
  const resChairStatus = document.getElementById('res-chair-status');
  const resChairContact = document.getElementById('res-chair-contact');
  const resChairEmail = document.getElementById('res-chair-email');
  const resChairPhone = document.getElementById('res-chair-phone');
  const resChairVacant = document.getElementById('res-chair-vacant');
  const resPollPlace = document.getElementById('res-poll-place');
  const resPollDetails = document.getElementById('res-poll-details');
  const resPollDirections = document.getElementById('res-poll-directions');

  function showPrecinct(pct) {
    if (!pct) {
      resultsContainer.classList.add('hidden');
      return;
    }

    resNumber.textContent = pct.number;
    resCoverage.textContent = pct.coverage;
    
    if (pct.mapUrl) {
      resMapLink.href = pct.mapUrl;
      document.getElementById('res-map-container').classList.remove('hidden');
    } else {
      document.getElementById('res-map-container').classList.add('hidden');
    }

    if (pct.name === 'Vacant') {
      resChairName.textContent = 'Position Vacant';
      resChairStatus.textContent = 'Help Organize Your Neighborhood';
      resChairContact.classList.add('hidden');
      resChairVacant.classList.remove('hidden');
    } else {
      resChairName.textContent = pct.name;
      resChairStatus.textContent = 'Official BCRP Precinct Chair';
      resChairContact.classList.remove('hidden');
      resChairVacant.classList.add('hidden');
      resChairEmail.href = `mailto:${pct.email}`;
      
      if (pct.phone) {
        resChairPhone.textContent = `Phone: ${pct.phone}`;
        resChairPhone.classList.remove('hidden');
      } else {
        resChairPhone.classList.add('hidden');
      }
    }

    // Split polling place name and address
    const pollParts = pct.pollingPlace.split(', ');
    const pollName = pollParts[0];
    const pollAddress = pollParts.slice(1).join(', ');
    resPollPlace.textContent = pollName;
    resPollDetails.textContent = pollAddress;
    resPollDirections.href = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(pct.pollingPlace)}`;

    resultsContainer.classList.remove('hidden');
  }

  // Handle dropdown selection
  selectElement?.addEventListener('change', (e) => {
    const value = e.target.value;
    if (value) {
      lookupInput.value = ''; // clear text input
      const matched = precincts.find(p => p.number === value);
      showPrecinct(matched);
    } else {
      resultsContainer.classList.add('hidden');
    }
  });

  // Handle street/neighborhood search
  lookupInput?.addEventListener('input', (e) => {
    const value = e.target.value.toLowerCase().trim();
    if (!value) {
      resultsContainer.classList.add('hidden');
      return;
    }

    selectElement.value = ''; // clear dropdown select

    // Find first matching precinct based on keywords or number
    const matched = precincts.find(p => 
      p.number.includes(value) || 
      p.keywords.includes(value) || 
      p.coverage.toLowerCase().includes(value)
    );

    showPrecinct(matched);
  });
</script>
