---
// DonationPopup.astro modified to show the event cover image popup
---

<div id="donation-popup" class="fixed inset-0 z-50 flex flex-col items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300 hidden">
  <!-- Backdrop -->
  <div id="donation-popup-backdrop" class="absolute inset-0 bg-navy/80 backdrop-blur-sm transition-opacity"></div>
  
  <!-- Popup Content -->
  <div class="relative bg-white rounded-xl shadow-2xl max-w-3xl w-full overflow-hidden transform scale-95 transition-transform duration-300" id="donation-popup-content">
    
    <!-- Close Button -->
    <button id="donation-popup-close" class="absolute top-3 right-3 bg-black/60 hover:bg-black/85 text-white rounded-full w-9 h-9 flex items-center justify-center transition-all z-20 shadow-md hover:scale-105 border border-white/20" aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    
    <!-- Image Link -->
    <a href="https://bastropctygop.wufoo.com/forms/m116bvtr08reo3b/" target="_blank" rel="noopener noreferrer" class="block group relative overflow-hidden">
      <img 
        src="/Assets/fb_event_cover_v4.png" 
        alt="Bastrop County Republican Party Event - Click to RSVP" 
        class="w-full h-auto block transition-transform duration-500 group-hover:scale-[1.01]"
      />
      <!-- Subtle hover overlay -->
      <div class="absolute inset-0 bg-navy/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
    </a>
  </div>
</div>

<script>
  // Script runs on client side
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('donation-popup');
    const backdrop = document.getElementById('donation-popup-backdrop');
    const content = document.getElementById('donation-popup-content');
    const closeBtn = document.getElementById('donation-popup-close');
    
    // Check if popup has been seen in this session
    // Using a specific key for this event so users who saw the old popup will see this new one
    const hasSeenPopup = sessionStorage.getItem('bcrp_event_popup_seen_v4');
    
    if (!hasSeenPopup && popup && backdrop && content && closeBtn) {
      // Show popup after 3 seconds of page load (slightly quicker engagement)
      setTimeout(() => {
        popup.classList.remove('hidden');
        
        // Small delay to allow display:block to apply before animating opacity
        requestAnimationFrame(() => {
          popup.classList.remove('opacity-0', 'pointer-events-none');
          content.classList.remove('scale-95');
          content.classList.add('scale-100');
        });
      }, 3000);
      
      const closePopup = () => {
        popup.classList.add('opacity-0', 'pointer-events-none');
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
        
        // Mark as seen so it doesn't show again this session
        sessionStorage.setItem('bcrp_event_popup_seen_v4', 'true');
        
        setTimeout(() => {
          popup.classList.add('hidden');
        }, 300); // Wait for transition to finish
      };
      
      // Close on button click
      closeBtn.addEventListener('click', closePopup);
      
      // Close on backdrop click
      backdrop.addEventListener('click', closePopup);
      
      // Close on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
          closePopup();
        }
      });
    }
  });
</script>
