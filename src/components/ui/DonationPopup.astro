---
import Button from './Button.astro';
---

<div id="donation-popup" class="fixed inset-0 z-50 flex flex-col items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300 hidden">
  <!-- Backdrop -->
  <div id="donation-popup-backdrop" class="absolute inset-0 bg-navy/80 backdrop-blur-sm transition-opacity"></div>
  
  <!-- Popup Content -->
  <div class="relative bg-white rounded-xl shadow-2xl max-w-2xl w-full overflow-hidden transform scale-95 transition-transform duration-300 max-h-[90vh] overflow-y-auto" id="donation-popup-content">
    
    <!-- Close Button -->
    <button id="donation-popup-close" class="absolute top-3 right-3 bg-white/90 backdrop-blur rounded-full w-8 h-8 flex items-center justify-center text-gray-600 hover:text-navy hover:bg-white transition-all z-20 shadow-md" aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    
    <!-- Header Image -->
    <div class="relative">
      <img 
        src="/Assets/donation_post_image_v2.png" 
        alt="Keep Bastrop County Red" 
        class="w-full h-auto"
      />
      <!-- Red banner overlay -->
      <div class="bg-red-primary text-white text-center py-2 px-4">
        <p class="text-sm sm:text-base font-extrabold tracking-wide uppercase">
          Stop the Liberal Takeover — Donate Today
        </p>
      </div>
    </div>
    
    <!-- Body -->
    <div class="p-6 sm:p-8 flex flex-col gap-4">
      <h3 class="text-xl sm:text-2xl font-extrabold text-navy leading-tight">
        Keep Bastrop County Red — We Need Your Support!
      </h3>
      
      <p class="text-text-secondary leading-relaxed text-sm sm:text-base">
        Bastrop County is a special place, rooted in strong conservative values, community, and freedom. But those values are under threat.
      </p>

      <p class="text-text-secondary leading-relaxed text-sm sm:text-base">
        The Democrats have made it clear: <strong class="text-text-primary">they want Bastrop County.</strong> Their goal is to push their agenda, flip our local elections, and turn our beautiful county into another Austin. We've seen what happens when those policies take over — higher taxes, more regulations, and a departure from the principles that make our community great.
      </p>

      <p class="text-text-secondary leading-relaxed text-sm sm:text-base">
        <strong class="text-text-primary">But we can stop them.</strong> The Bastrop County Republican Party is fighting every day to defend our values, support strong conservative candidates, and ensure our county remains a beacon of liberty in Texas. <strong class="text-text-primary">We cannot do this without you.</strong> Your contribution today directly funds our grassroots efforts to register voters, get out the vote, and push back against the liberal agenda. Every dollar counts in the fight to keep Bastrop County red.
      </p>

      <p class="text-text-secondary leading-relaxed text-sm sm:text-base">
        Together, we can protect our home. Stand with us, make a donation, and let's keep Bastrop County true to its roots!
      </p>

      <p class="text-sm font-semibold text-navy italic">
        Thank you for your unwavering support.
      </p>
      
      <div class="pt-2">
        <Button 
          href="https://square.link/u/p4rKmX9I" 
          variant="primary" 
          size="lg" 
          class="w-full text-center justify-center text-base sm:text-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all"
          external
        >
          ★ Donate Now – Keep Bastrop County Red ★
        </Button>
      </div>
      
      <!-- Hashtags -->
      <div class="flex flex-wrap gap-2 pt-1">
        <span class="text-xs font-semibold text-red-primary">#BastropCounty</span>
        <span class="text-xs font-semibold text-red-primary">#KeepBastropRed</span>
        <span class="text-xs font-semibold text-red-primary">#Texas</span>
        <span class="text-xs font-semibold text-red-primary">#BCRP</span>
        <span class="text-xs font-semibold text-red-primary">#StopTheTakeover</span>
      </div>

      <!-- Disclaimer -->
      <div class="text-xs text-gray-500 mt-1 bg-gray-50 p-3 rounded-md border border-gray-100">
        <p class="mb-1">
          Texas Ethics Commission rules may require donor information including name, address, occupation, and employer for certain contributions.
        </p>
        <p>
          Donations are not tax deductible and must comply with federal and Texas election laws.
        </p>
      </div>
    </div>
    
  </div>
</div>

<script>
  // Script runs on client side
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('donation-popup');
    const backdrop = document.getElementById('donation-popup-backdrop');
    const content = document.getElementById('donation-popup-content');
    const closeBtn = document.getElementById('donation-popup-close');
    
    // Check if popup has been seen in this session
    const hasSeenPopup = sessionStorage.getItem('bcrp_donation_popup_seen');
    
    if (!hasSeenPopup && popup && backdrop && content && closeBtn) {
      // Show popup after 5 seconds of page load
      setTimeout(() => {
        popup.classList.remove('hidden');
        
        // Small delay to allow display:block to apply before animating opacity
        requestAnimationFrame(() => {
          popup.classList.remove('opacity-0', 'pointer-events-none');
          content.classList.remove('scale-95');
          content.classList.add('scale-100');
        });
      }, 5000);
      
      const closePopup = () => {
        popup.classList.add('opacity-0', 'pointer-events-none');
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
        
        // Mark as seen so it doesn't show again this session
        sessionStorage.setItem('bcrp_donation_popup_seen', 'true');
        
        setTimeout(() => {
          popup.classList.add('hidden');
        }, 300); // Wait for transition to finish
      };
      
      // Close on button click
      closeBtn.addEventListener('click', closePopup);
      
      // Close on backdrop click
      backdrop.addEventListener('click', closePopup);
      
      // Close on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
          closePopup();
        }
      });
    }
  });
</script>
