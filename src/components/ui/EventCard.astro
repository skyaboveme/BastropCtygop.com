---
interface Props {
  title: string;
  date: Date;
  time?: string;
  location?: string;
  href: string;
  category?: string;
}

const { title, date, time, location, href, category } = Astro.props;

const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const month = months[date.getUTCMonth()];
const day = date.getUTCDate();
---

<article class="group flex gap-4 bg-white rounded-xl border border-gray-medium p-4 lg:p-5 hover:shadow-[var(--shadow-card-hover)] transition-all duration-300 relative">
  <!-- Date Badge -->
  <div class="shrink-0 w-16 h-16 bg-navy rounded-lg flex flex-col items-center justify-center text-white">
    <span class="text-xs font-bold uppercase tracking-wider leading-none">{month}</span>
    <span class="text-2xl font-extrabold leading-none mt-0.5">{day}</span>
  </div>

  <!-- Event Info -->
  <div class="min-w-0 flex-1">
    {category && (
      <span class="text-xs font-semibold text-red-primary uppercase tracking-wide">{category}</span>
    )}
    <h3 class="text-base font-bold text-text-primary group-hover:text-navy transition-colors leading-snug mt-0.5">
      <a href={href} class="after:absolute after:inset-0">
        {title}
      </a>
    </h3>
    <div class="flex flex-wrap items-center gap-3 mt-1.5 text-sm text-text-secondary">
      {time && (
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {time}
        </span>
      )}
      {location && (
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
          {location}
        </span>
      )}
    </div>
  </div>
</article>
