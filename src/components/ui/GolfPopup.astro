---
// GolfPopup.astro
---

<div id="golf-promo-popup" class="fixed inset-0 bg-navy/80 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all duration-500 opacity-0 pointer-events-none" aria-hidden="true">
  <div id="golf-popup-content" class="bg-white rounded-lg shadow-2xl relative w-full max-w-[1000px] transform scale-95 transition-transform duration-500 delay-100 mt-10">
    
    <!-- Close Button -->
    <button id="close-golf-popup" class="absolute -top-4 -right-4 md:-top-5 md:-right-5 bg-red-primary text-white rounded-full w-10 h-10 flex items-center justify-center shadow-xl border-2 border-white hover:bg-red-dark hover:scale-110 transition-all z-10" aria-label="Close popup">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <!-- Exact Promo Banner Design -->
    <a href="/events/golf-classic/" class="block overflow-hidden rounded-lg group">
      <!-- Top Title Bar -->
      <div class="border-t-4 border-red-primary bg-gray-200 py-3 text-center transition-colors group-hover:bg-gray-300">
        <h2 class="text-2xl md:text-4xl font-extrabold text-black tracking-tight" style="font-family: Arial, sans-serif;">BCRP 4th Annual Golf Classic</h2>
      </div>
      <!-- Banner Body -->
      <div class="relative bg-green-200 bg-cover bg-center min-h-[220px] md:min-h-[280px]" style="background-image: url('/golf_banner_bg.png');">
        <!-- Light overlay for text legibility -->
        <div class="absolute inset-0 bg-white/40 group-hover:bg-white/30 transition-colors duration-300"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between p-6 md:p-8 h-full gap-6">
          
          <!-- Left: Logo & Title Area -->
          <div class="flex items-center gap-4 md:gap-8">
            <img src="/BCRP-Logo.webp" alt="BCRP Logo" class="w-28 h-28 md:w-44 md:h-44 object-contain drop-shadow-xl shrink-0" />
            <div class="flex flex-col text-left">
              <span class="text-gray-900 font-extrabold text-xl md:text-3xl drop-shadow-md mb-[-0.2rem]">4th Annual</span>
              <span class="text-[#3b5926] font-black text-5xl md:text-7xl leading-none tracking-tight shadow-black drop-shadow-sm" style="-webkit-text-stroke: 1px #111;">Golf</span>
              <span class="text-[#3b5926] font-black text-5xl md:text-7xl leading-none tracking-tight shadow-black drop-shadow-sm" style="-webkit-text-stroke: 1px #111;">Classic</span>
            </div>
          </div>

          <!-- Right: Details Area -->
          <div class="flex flex-col text-left mt-4 md:mt-0 lg:pr-8">
            <h3 class="text-[#4b6b33] font-black text-2xl md:text-3xl lg:text-4xl drop-shadow-md mb-2 pb-1">Four Man Scramble</h3>
            <p class="text-black font-bold text-lg md:text-xl leading-snug drop-shadow-sm">Friday, April 10, 2026</p>
            <p class="text-black font-medium text-base md:text-lg leading-snug drop-shadow-sm">Check in at 11 AM</p>
            <p class="text-black font-medium text-base md:text-lg leading-snug drop-shadow-sm">Shotgun start at 12 PM</p>
          </div>
        </div>
      </div>
    </a>
  </div>
</div>

<script>
  // Setup the modal logic
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('golf-promo-popup');
    const content = document.getElementById('golf-popup-content');
    const closeBtn = document.getElementById('close-golf-popup');
    
    if (!popup || !content || !closeBtn) return;
    
    // Check if the user has already seen the popup in this session
    const hasSeenPopup = sessionStorage.getItem('golfPopupSeen');
    
    if (!hasSeenPopup) {
      // Delay showing the popup to allow the page behind to visually settle
      setTimeout(() => {
        popup.classList.remove('opacity-0', 'pointer-events-none');
        popup.setAttribute('aria-hidden', 'false');
        content.classList.remove('scale-95');
        
        // Mark as seen
        sessionStorage.setItem('golfPopupSeen', 'true');
      }, 1000);
    }
    
    const closePopup = () => {
      popup.classList.add('opacity-0', 'pointer-events-none');
      popup.setAttribute('aria-hidden', 'true');
      content.classList.add('scale-95');
    };
    
    // Event listeners
    closeBtn.addEventListener('click', closePopup);
    
    // Close on background click
    popup.addEventListener('click', (e) => {
      if (e.target === popup) closePopup();
    });
    
    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !popup.classList.contains('opacity-0')) {
        closePopup();
      }
    });
  });
</script>
