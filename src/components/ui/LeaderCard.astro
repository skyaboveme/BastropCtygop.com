---
interface Props {
  name: string;
  title: string;
  email?: string;
  phone?: string;
  photo?: string;
}

const { name, title, email, phone, photo } = Astro.props;

const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2);
---

<div class="bg-white rounded-xl border border-gray-medium p-5 text-center hover:shadow-[var(--shadow-card-hover)] transition-all duration-300">
  <!-- Photo / Placeholder -->
  <div class="w-20 h-20 rounded-full mx-auto mb-4 overflow-hidden bg-navy/10 flex items-center justify-center">
    {photo ? (
      <img src={photo} alt={name} class="w-full h-full object-cover" loading="lazy" />
    ) : (
      <span class="text-2xl font-bold text-navy">{initials}</span>
    )}
  </div>

  <h3 class="text-base font-bold text-text-primary">{name}</h3>
  <p class="text-sm text-red-primary font-medium mt-1">{title}</p>

  <div class="mt-3 flex items-center justify-center gap-2">
    {email && (
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-1 text-xs text-navy hover:text-red-primary transition-colors"
        aria-label={`Email ${name}`}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Email
      </a>
    )}
    {phone && (
      <a
        href={`tel:${phone.replace(/\D/g, '')}`}
        class="inline-flex items-center gap-1 text-xs text-navy hover:text-red-primary transition-colors"
        aria-label={`Call ${name}`}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call
      </a>
    )}
  </div>
</div>
