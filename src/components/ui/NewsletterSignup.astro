---
---

<section class="bg-navy py-12 lg:py-16">
  <div class="container max-w-2xl text-center">
    <h2 class="text-2xl lg:text-3xl font-extrabold text-white mb-3">Stay Informed</h2>
    <p class="text-white/70 mb-8">Get BCRP news, event announcements, and important updates delivered to your inbox.</p>
    <form class="flex flex-col sm:flex-row gap-3" action="#" method="POST" id="newsletter-form">
      <input
        type="text"
        name="name"
        placeholder="Your Name"
        required
        class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder:text-white/50 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent"
      />
      <input
        type="email"
        name="email"
        placeholder="Your Email"
        required
        class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder:text-white/50 focus:outline-none focus:ring-2 focus:ring-red-primary focus:border-transparent"
      />
      <button
        type="submit"
        class="bg-red-primary hover:bg-red-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors shrink-0"
      >
        Subscribe
      </button>
    </form>
    <p class="text-xs text-white/40 mt-4">We respect your privacy. Unsubscribe at any time.</p>
  </div>
</section>
