---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  {
    label: 'News',
    href: '/news/',
    children: [
      { label: 'Latest News', href: '/news/' },
      { label: 'Legislative Updates', href: '/news/category/legislative-review/' },
      { label: 'Election News', href: '/news/category/election/' },
      { label: 'Convention News', href: '/news/category/convention/' },
    ],
  },
  {
    label: 'Events',
    href: '/events/',
    children: [
      { label: 'Calendar', href: '/events/' },
      { label: 'Conventions', href: '/events/conventions/' },
      { label: 'Monthly Meetings', href: '/events/monthly-meetings/' },
      { label: 'Annual Golf Classic', href: '/events/golf-classic/' },
    ],
  },
  {
    label: 'About',
    href: '/about/who-we-are/',
    children: [
      { label: 'Who We Are', href: '/about/who-we-are/' },
      { label: 'County Chair', href: '/about/county-chair/' },
      { label: 'Leadership Team', href: '/about/leadership/' },
      { label: 'Precinct Chairs', href: '/about/precinct-chairs/' },
      { label: 'Precinct Chair FAQs', href: '/about/precinct-chair-faqs/' },
      { label: 'Bylaws', href: '/about/bylaws/' },
      { label: 'State GOP Leadership', href: '/about/state-gop-leadership/' },
    ],
  },
  {
    label: 'Resources',
    href: '/resources/elected-officials/',
    children: [
      { label: 'Elected Officials', href: '/resources/elected-officials/' },
      { label: 'Bastrop Votes', href: 'https://bastropvotes.org', external: true },
      { label: 'Precinct Maps', href: '/resources/precinct-maps/' },
      { label: 'Commenting Policy', href: '/about/commenting-policy/' },
    ],
  },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 w-full border-b border-gray-200 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80 transition-all duration-300" id="site-header">
  <div class="container mx-auto">
    <div class="flex items-center justify-between h-20 lg:h-24">
      <!-- Logo & Brand Lockup -->
      <a href="/" class="flex items-center gap-3 shrink-0 transition-opacity hover:opacity-90" aria-label="Bastrop County Republican Party Home">
        <img
          src="/BCRP-Logo.webp"
          alt="Bastrop County Republican Party Logo"
          class="h-14 w-14 md:h-16 md:w-16 object-contain"
        />
        <div class="hidden sm:block">
          <h1 class="text-2xl md:text-3xl font-serif font-bold text-navy leading-none uppercase">Bastrop County</h1>
          <p class="text-[0.7rem] md:text-xs font-bold tracking-[0.2em] text-red-primary uppercase mt-1.5">Republican Party</p>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-2" aria-label="Primary navigation">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class={`px-3 py-2 text-sm font-medium rounded-md transition-colors duration-200 inline-flex items-center gap-1 ${
                isActive(item.href)
                  ? 'text-navy font-bold'
                  : 'text-text-muted hover:text-navy hover:bg-gray-50'
              }`}
            >
              {item.label}
              {item.children && (
                <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute left-0 top-full pt-2 invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 z-50">
                <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 min-w-[220px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class={`block px-4 py-2 text-sm transition-colors duration-150 ${
                        currentPath === child.href
                          ? 'text-navy font-bold bg-gray-50'
                          : 'text-text-muted hover:text-navy hover:bg-gray-50'
                      }`}
                      {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    >
                      {child.label}
                      {child.external && (
                        <svg class="w-3 h-3 inline ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- Right Side: Donate + Mobile Menu -->
      <div class="flex items-center gap-3">
        <a
          href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center justify-center bg-red-primary hover:bg-red-dark text-white font-bold text-sm h-9 px-5 rounded-md transition-colors shadow-sm"
          id="donate-button-header"
        >
          Donate
        </a>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="lg:hidden p-2 rounded-md text-text-primary hover:bg-gray-100 transition-colors"
          aria-label="Open navigation menu"
          aria-expanded="false"
          id="mobile-menu-toggle"
        >
          <svg class="w-6 h-6" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden hidden border-t border-gray-200 bg-white" id="mobile-menu" role="navigation" aria-label="Mobile navigation">
    <div class="container py-4 space-y-1">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class={`block px-4 py-3 text-sm font-medium rounded-md transition-colors ${
              isActive(item.href)
                ? 'text-navy font-bold bg-gray-50'
                : 'text-text-muted hover:text-navy hover:bg-gray-50'
            }`}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="pl-4 space-y-0.5 mt-1 border-l-2 border-gray-100 ml-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class={`block px-4 py-2 text-sm rounded-md transition-colors ${
                    currentPath === child.href
                      ? 'text-navy font-bold'
                      : 'text-text-muted hover:text-navy hover:bg-gray-50'
                  }`}
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="pt-4 mt-4 border-t border-gray-200">
        <a
          href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center bg-red-primary hover:bg-red-dark text-white font-bold text-sm h-10 px-5 rounded-md transition-colors"
        >
          Donate
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Sticky header shrink on scroll
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const header = document.getElementById('site-header');
    if (!header) return;
    if (window.scrollY > 20) {
      header.classList.add('shadow-sm');
    } else {
      header.classList.remove('shadow-sm');
    }
    lastScroll = window.scrollY;
  });
</script>
