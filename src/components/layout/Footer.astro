---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy text-white mt-auto">
  <div class="container py-12 lg:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Column 1: About -->
      <div>
        <h3 class="text-lg font-bold mb-4 text-white">About Us</h3>
        <ul class="space-y-2.5">
          <li><a href="/about/county-chair/" class="text-white/70 hover:text-white transition-colors text-sm">County Chair</a></li>
          <li><a href="/about/precinct-chairs/" class="text-white/70 hover:text-white transition-colors text-sm">Precinct Chairs</a></li>
          <li><a href="/about/leadership/" class="text-white/70 hover:text-white transition-colors text-sm">Leadership Team</a></li>
          <li><a href="/about/bylaws/" class="text-white/70 hover:text-white transition-colors text-sm">Bylaws</a></li>
          <li><a href="/about/commenting-policy/" class="text-white/70 hover:text-white transition-colors text-sm">Commenting Policy</a></li>
        </ul>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-4 text-white">Quick Links</h3>
        <ul class="space-y-2.5">
          <li><a href="/events/" class="text-white/70 hover:text-white transition-colors text-sm">Events Calendar</a></li>
          <li><a href="/events/monthly-meetings/" class="text-white/70 hover:text-white transition-colors text-sm">Monthly Meetings</a></li>
          <li><a href="/about/precinct-chairs/" class="text-white/70 hover:text-white transition-colors text-sm">Find Your Precinct Chair</a></li>
          <li><a href="/news/" class="text-white/70 hover:text-white transition-colors text-sm">Latest News</a></li>
          <li>
            <a href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors text-sm">
              Donate
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Contact Info -->
      <div>
        <h3 class="text-lg font-bold mb-4 text-white">Contact</h3>
        <address class="not-italic space-y-2.5 text-sm text-white/70">
          <p>443 Highway 71 West<br />Bastrop, TX 78602</p>
          <p>
            <a href="tel:5124091415" class="hover:text-white transition-colors">Office: 512.409.1415</a>
          </p>
          <p>
            <a href="tel:5128252707" class="hover:text-white transition-colors">County Chair: (512) 825-2707</a>
          </p>
          <div class="pt-1">
            <p class="font-medium text-white/90">Office Hours</p>
            <p>Tues, Weds, Fri, Sat: 10am - 2pm</p>
            <p>Thurs: 2pm - 6pm</p>
          </div>
        </address>
      </div>

      <!-- Column 4: Social Media -->
      <div>
        <h3 class="text-lg font-bold mb-4 text-white">Connect</h3>
        <div class="flex gap-4">
          <a
            href="https://www.facebook.com/BCRPBastropTX"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://twitter.com/BastropCtyGOP"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
            aria-label="Twitter / X"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
        <div class="mt-6">
          <a
            href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-red-primary hover:bg-red-dark text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors"
          >
            Donate Today
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer Bar -->
  <div class="border-t border-white/10 bg-navy-dark">
    <div class="container py-4">
      <p class="text-xs text-white/50 text-center leading-relaxed">
        This website is political advertising paid for by the Bastrop County Republican Party. Contributions to the Bastrop County Republican Party are not tax deductible as charitable contributions for Federal income tax purposes. This website is not authorized by any candidate or candidate committee. All design and content &copy; 2025-{currentYear}.
      </p>
    </div>
  </div>
</footer>
