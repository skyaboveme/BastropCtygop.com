---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy text-white mt-16 lg:mt-24 border-t-[6px] border-red-primary relative z-10 w-full overflow-hidden">
  <!-- Background Texture -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-15 mix-blend-color-burn">
    <img 
      src="/waving_texas_flag_texture.png" 
      alt="" 
      class="w-full h-full object-cover object-center grayscale"
    />
  </div>
  
  <div class="container py-16 lg:py-20 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">
      
      <!-- Brand & Mission (Col span 4) -->
      <div class="lg:col-span-4 flex flex-col items-start pr-4">
        <div class="bg-white p-2 md:p-3 rounded-2xl shadow-md mb-6 mt-2 inline-block">
          <img src="/BCRP-Logo.webp" alt="Bastrop County GOP Logo" class="w-16 h-16 md:w-20 md:h-20 object-contain" />
        </div>
        <h3 class="text-2xl font-extrabold mb-3 tracking-tight text-white">Bastrop County GOP</h3>
        <p class="text-white/70 text-sm leading-relaxed mb-8 max-w-sm">
          The Official Representatives for the Republican Party of Texas in Bastrop County. We believe in conservative principles, individual liberty, and strong communities.
        </p>
        <a href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-red-primary hover:bg-red-dark text-white font-bold text-sm px-7 py-3.5 rounded-lg transition-transform hover:-translate-y-0.5 shadow-lg w-full sm:w-auto">
          Support Our Mission
        </a>
      </div>

      <!-- Quick Links (Col span 2) -->
      <div class="lg:col-span-2 pt-6 lg:pt-8">
        <h4 class="text-[11px] font-bold uppercase tracking-widest text-white/50 mb-6">Explore</h4>
        <ul class="space-y-3.5">
          <li><a href="/events/" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">Events Calendar</a></li>
          <li><a href="/news/" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">Latest News</a></li>
          <li><a href="/about/county-chair/" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">County Chair</a></li>
          <li><a href="/about/leadership/" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">Leadership Team</a></li>
          <li><a href="/about/precinct-chairs/" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">Precinct Chairs</a></li>
        </ul>
      </div>

      <!-- Action & Info (Col span 2) -->
      <div class="lg:col-span-2 pt-6 lg:pt-8">
        <h4 class="text-[11px] font-bold uppercase tracking-widest text-white/50 mb-6">Resources</h4>
        <ul class="space-y-3.5">
          <li><a href="/about/bylaws/" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">Bylaws</a></li>
          <li><a href="/about/commenting-policy/" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">Commenting Policy</a></li>
          <li><a href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/" target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white hover:translate-x-1 inline-block transition-all text-sm font-medium">Donate</a></li>
        </ul>
      </div>

      <!-- Contact & Social (Col span 4) -->
      <div class="lg:col-span-4 lg:pl-4 pt-6 lg:pt-8">
        <h4 class="text-[11px] font-bold uppercase tracking-widest text-white/50 mb-6">Contact & Connect</h4>
        
        <div class="space-y-4 text-sm text-white/80 font-medium mb-8">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-white/80 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <p class="leading-relaxed">443 Highway 71 West<br/>Bastrop, TX 78602</p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-white/80 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:5124091415" class="hover:text-white transition-colors">Office: 512.409.1415</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-white/80 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            <a href="tel:5128252707" class="hover:text-white transition-colors">County Chair: (512) 825-2707</a>
          </div>
        </div>

        <div class="flex gap-4">
          <a href="https://www.facebook.com/BCRPBastropTX" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-white/10 hover:bg-[#1877F2] hover:-translate-y-1 flex items-center justify-center transition-all duration-300 shadow-sm" aria-label="Facebook">
            <svg class="w-5 h-5 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14 13.5h2.5l1-4H14v-2c0-1.03 0-2 2-2h1.5V2.14c-.326-.043-1.557-.14-2.857-.14C11.928 2 10 3.657 10 6.7v2.8H7v4h3V22h4v-8.5z"/>
            </svg>
          </a>
          <a href="https://twitter.com/BastropCtyGOP" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-white/10 hover:bg-[#000000] hover:-translate-y-1 flex items-center justify-center transition-all duration-300 shadow-sm" aria-label="X (Twitter)">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer / Bottom Bar -->
  <div class="border-t border-white/5 bg-black/20">
    <div class="container py-6">
      <div class="flex flex-col lg:flex-row justify-between items-center gap-6">
        <p class="text-[11px] text-white/50 text-center lg:text-left leading-relaxed max-w-4xl tracking-wide">
          This website is political advertising paid for by the Bastrop County Republican Party. Contributions to the Bastrop County Republican Party are not tax deductible as charitable contributions for Federal income tax purposes. This website is not authorized by any candidate or candidate committee.
        </p>
        <p class="text-[11px] text-white/50 font-bold tracking-wider whitespace-nowrap">
          &copy; {currentYear} BASTROP COUNTY GOP
        </p>
      </div>
    </div>
  </div>
</footer>
