---
const currentYear = new Date().getFullYear();
---

<footer class="text-white mt-auto" style="background-color: #3f4c8c;">
  <div class="container pt-16 pb-12 lg:pt-20 lg:pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 pl-2">
      <!-- Column 1: About Us -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-white tracking-wide">About Us</h3>
        <ul class="space-y-3">
          <li><a href="/about/county-chair/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">County Chair</a></li>
          <li><a href="/about/precinct-chairs/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Precinct Chairs</a></li>
          <li><a href="/about/leadership/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Leadership Team</a></li>
          <li><a href="/about/bylaws/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Bylaws</a></li>
          <li><a href="/about/commenting-policy/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Commenting Policy</a></li>
        </ul>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-white tracking-wide">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="/events/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Events Calendar</a></li>
          <li><a href="/events/monthly-meetings/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Monthly Meetings</a></li>
          <li><a href="/about/precinct-chairs/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Find Your Precinct Chair</a></li>
          <li><a href="/news/" class="text-white/80 hover:text-white transition-colors text-sm font-medium">Latest News</a></li>
          <li>
            <a href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/" target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white transition-colors text-sm font-medium">
              Donate
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Contact Info -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-white tracking-wide">Contact</h3>
        <address class="not-italic text-sm text-white/80 font-medium space-y-4">
          <div class="leading-relaxed">
            <p>443 Highway 71 West</p>
            <p>Bastrop, TX 78602</p>
          </div>
          <div class="space-y-3">
            <p>
              <a href="tel:5124091415" class="hover:text-white transition-colors">Office: 512.409.1415</a>
            </p>
            <p>
              <a href="tel:5128252707" class="hover:text-white transition-colors">County Chair: (512) 825-2707</a>
            </p>
          </div>
          <div class="pt-2">
            <p class="font-bold text-white mb-1">Office Hours</p>
            <p class="mb-1">Tues, Weds, Fri, Sat: 10am - 2pm</p>
            <p>Thurs: 2pm - 6pm</p>
          </div>
        </address>
      </div>

      <!-- Column 4: Social Media -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-white tracking-wide">Connect</h3>
        <div class="flex gap-4">
          <a
            href="https://www.facebook.com/BCRPBastropTX"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14 13.5h2.5l1-4H14v-2c0-1.03 0-2 2-2h1.5V2.14c-.326-.043-1.557-.14-2.857-.14C11.928 2 10 3.657 10 6.7v2.8H7v4h3V22h4v-8.5z"/>
            </svg>
          </a>
          <a
            href="https://twitter.com/BastropCtyGOP"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center transition-colors"
            aria-label="Twitter / X"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
        <div class="mt-8">
          <a
            href="https://bastropctygop.wufoo.com/forms/zwcqdgs1ydkjyo/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#b81c1c] hover:bg-red-800 text-white font-bold text-sm px-6 py-3 rounded-lg transition-colors shadow-md shadow-black/20"
          >
            Donate Today
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Disclaimer Bar -->
  <div class="border-t border-white/10" style="background-color: #333f75;">
    <div class="container py-4 flex justify-center">
      <p class="text-xs text-white/50 text-center leading-relaxed max-w-5xl">
        This website is political advertising paid for by the Bastrop County Republican Party. Contributions to the Bastrop County Republican Party are not tax deductible as charitable contributions for Federal income tax purposes. This website is not authorized by any candidate or candidate committee. All design and content &copy; 2025-{currentYear}.
      </p>
    </div>
  </div>
</footer>
